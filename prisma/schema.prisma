generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  role          String    @default("user")
  tag           String?   // professional tag: "courtier", "notaire", "finance", etc.

  // Email notification preferences
  emailNotifComments Boolean @default(true)
  emailNotifReplies  Boolean @default(true)
  emailNotifMentions Boolean @default(true)
  emailNotifMessages Boolean @default(true)
  emailNotifAnnonces Boolean @default(true)

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  votes         Vote[]
  commentVotes  CommentVote[]
  reports       Report[]
  notifications Notification[]
  bookmarks     Bookmark[]
  listings         Listing[]
  listingFavorites ListingFavorite[]
  listingComments  ListingComment[]
  savedReports     SavedReport[]
  conversationsAsUser1 Conversation[] @relation("ConvUser1")
  conversationsAsUser2 Conversation[] @relation("ConvUser2")
  messagesSent     Message[]
  alertesMarketplace  AlerteMarketplace[]
  quartierSubs        QuartierSubscription[]
  pollVotes           PollVote[]
  quartierReviews     QuartierReview[]
  savedSearches       SavedSearch[]
  sellerReviews       SellerReview[]   @relation("SellerReviews")
  reviewerReviews     SellerReview[]   @relation("ReviewerReviews")
  proProfile          ProProfile?
  proVotes            ProVote[]
}

model Post {
  id             String   @id @default(cuid())
  titre          String
  contenu        String
  auteurNom      String
  auteurId       String?
  quartierSlug   String
  villeSlug      String
  categorie      String
  imageUrl       String?
  nbCommentaires Int      @default(0)
  nbVotes        Int      @default(0)
  nbVues         Int      @default(0)
  epingle        Boolean  @default(false)
  creeLe         DateTime @default(now())

  auteur    User?      @relation(fields: [auteurId], references: [id], onDelete: SetNull)
  comments  Comment[]
  votes     Vote[]
  bookmarks Bookmark[]
  poll      Poll?

  @@index([villeSlug])
  @@index([quartierSlug])
  @@index([categorie])
  @@index([villeSlug, quartierSlug])
  @@index([creeLe])
  @@index([nbVotes])
  @@index([nbCommentaires])
  @@index([epingle])
}

model Vote {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  contenu   String
  imageUrl  String?
  auteurNom String
  auteurId  String?
  postId    String
  parentId  String?
  nbVotes   Int      @default(0)
  creeLe    DateTime @default(now())

  auteur  User?       @relation(fields: [auteurId], references: [id], onDelete: SetNull)
  post    Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?    @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]   @relation("Replies")
  votes   CommentVote[]

  @@index([postId])
  @@index([parentId])
}

model CommentVote {
  id        String @id @default(cuid())
  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String   // "comment" | "reply"
  postId     String
  postTitre  String
  acteurNom  String
  lu         Boolean  @default(false)
  creeLe     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lu])
}

model Report {
  id       String   @id @default(cuid())
  type     String
  targetId String
  reason   String
  auteurId String?
  creeLe   DateTime @default(now())

  auteur User? @relation(fields: [auteurId], references: [id], onDelete: SetNull)

  @@index([targetId])
}

model Bookmark {
  id     String   @id @default(cuid())
  userId String
  postId String
  creeLe DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

model Listing {
  id            String   @id @default(cuid())
  titre         String
  description   String
  prix          Int
  mode          String   @default("vente") // "vente" | "location"
  type          String   // "unifamiliale" | "condo" | "duplex" | "triplex" | "quadruplex" | "1_et_demi" | "2_et_demi" | "3_et_demi" | "4_et_demi" | "5_et_demi" | "6_et_demi" | "studio" | "loft"
  style         String?  // "maison_de_ville" | "cottage" | "bungalow" | "loft" etc.
  quartierSlug  String
  villeSlug     String   @default("montreal")
  adresse       String
  chambres      Int      @default(0)
  sallesDeBain  Int      @default(0)
  superficie    Int      @default(0) // pi²
  superficieTerrain Int? // pi²
  anneeConstruction Int?
  stationnement String?  // "aucun" | "entree" | "garage_simple" | "garage_double" | "interieur"
  chauffage     String?
  eauChaude     String?
  sousSol       String?
  piscine       String?
  taxesMunicipales Int?  // $ / an
  taxesScolaires   Int?  // $ / an
  fraisCondo       Int?  // $ / mois
  lienVisite    String?  // URL visite virtuelle
  disponibleLe  DateTime? // date de disponibilité (location)
  meuble        Boolean  @default(false) // meublé (location)
  inclusions    String?  // "chauffage, eau chaude, électricité" (location)
  anonyme       Boolean  @default(false)  // masquer le username du propriétaire
  telephone     String?  // numéro affiché si le propriétaire le souhaite
  statut        String   @default("active") // "active" | "vendu" | "retire"
  nbVues        Int      @default(0)
  nbClics       Int      @default(0)  // clics depuis la liste
  auteurId      String
  creeLe        DateTime @default(now())
  modifieLe     DateTime @updatedAt

  auteur    User              @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  images    ListingImage[]
  documents ListingDocument[]
  favoris   ListingFavorite[]
  commentaires   ListingComment[]
  prixHistorique ListingPriceHistory[]
  conversations  Conversation[]

  @@index([villeSlug])
  @@index([quartierSlug])
  @@index([type])
  @@index([statut])
  @@index([prix])
  @@index([creeLe])
  @@index([auteurId])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  position  Int     @default(0)
  principale Boolean @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingDocument {
  id        String @id @default(cuid())
  listingId String
  nom       String
  url       String
  taille    String? // "2,4 Mo" etc.

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingFavorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  creeLe    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

model ListingPriceHistory {
  id        String   @id @default(cuid())
  listingId String
  prix      Int
  evenement String   // "mise_en_vente" | "reduction" | "augmentation"
  creeLe    DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ListingComment {
  id         String   @id @default(cuid())
  contenu    String
  auteurNom  String
  auteurId   String?
  listingId  String
  creeLe     DateTime @default(now())

  auteur  User?   @relation(fields: [auteurId], references: [id], onDelete: SetNull)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Conversation {
  id         String   @id @default(cuid())
  user1Id    String
  user2Id    String
  listingId  String?  // optionnel — si la conversation est liée à une annonce
  lastMsg    String?  // aperçu du dernier message
  lastMsgAt  DateTime @default(now())
  creeLe     DateTime @default(now())

  user1    User      @relation("ConvUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConvUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([user1Id, user2Id, listingId])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMsgAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  auteurId       String
  contenu        String
  lu             Boolean  @default(false)
  creeLe         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  auteur       User         @relation(fields: [auteurId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([auteurId])
}

model SavedReport {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "hypothecaire" | "plex" | "acheter_louer"
  titre     String
  donnees   String   // JSON string of all input values
  resultats String   // JSON string of computed results
  creeLe    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  creeLe    DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  creeLe    DateTime @default(now())
}

model AlerteMarketplace {
  id            String   @id @default(cuid())
  userId        String
  villeSlug     String?
  quartierSlug  String?
  type          String?  // "unifamiliale" | "condo" | "duplex" etc.
  prixMax       Int?
  prixMin       Int?
  chambresMin   Int?
  active        Boolean  @default(true)
  creeLe        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

model QuartierSubscription {
  id           String   @id @default(cuid())
  userId       String
  quartierSlug String
  creeLe       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quartierSlug])
  @@index([userId])
  @@index([quartierSlug])
}

model Poll {
  id      String   @id @default(cuid())
  postId  String   @unique
  creeLe  DateTime @default(now())

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  label  String

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id       String   @id @default(cuid())
  pollId   String
  optionId String
  userId   String
  creeLe   DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
}

model QuartierReview {
  id           String   @id @default(cuid())
  userId       String
  quartierSlug String
  securite     Int      // 1-5
  transport    Int      // 1-5
  commerces    Int      // 1-5
  ecoles       Int      // 1-5
  ambiance     Int      // 1-5
  commentaire  String?
  creeLe       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quartierSlug])
  @@index([quartierSlug])
}

model SavedSearch {
  id         String   @id @default(cuid())
  userId     String
  nom        String
  mode       String?
  villeSlug  String?
  type       String?
  prixMax    Int?
  creeLe     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SellerReview {
  id         String   @id @default(cuid())
  sellerId   String
  reviewerId String
  listingId  String?
  note       Int      // 1-5
  commentaire String?
  creeLe     DateTime @default(now())

  seller   User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  reviewer User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, reviewerId, listingId])
  @@index([sellerId])
}

model ProProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  nomEntreprise String
  specialite    String   // "courtier", "notaire", "finance", "entrepreneur", "electricien", "plombier", "charpentier", "inspecteur", "architecte", "designer", "demenagement", "nettoyage", "autre"
  description   String
  telephone     String?
  courriel      String?
  siteWeb       String?
  villeSlug     String
  imageUrl      String?
  nbVotes       Int      @default(0)
  creeLe        DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes ProVote[]

  @@index([specialite])
  @@index([villeSlug])
  @@index([nbVotes])
}

model ProVote {
  id           String @id @default(cuid())
  userId       String
  proProfileId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proProfile ProProfile @relation(fields: [proProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, proProfileId])
}
