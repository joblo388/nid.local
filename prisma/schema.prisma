generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  role          String    @default("user")

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  votes         Vote[]
  reports       Report[]
  notifications Notification[]
}

model Post {
  id             String   @id @default(cuid())
  titre          String
  contenu        String
  auteurNom      String
  auteurId       String?
  quartierSlug   String
  villeSlug      String
  categorie      String
  imageUrl       String?
  nbCommentaires Int      @default(0)
  nbVotes        Int      @default(0)
  nbVues         Int      @default(0)
  epingle        Boolean  @default(false)
  creeLe         DateTime @default(now())

  auteur   User?     @relation(fields: [auteurId], references: [id], onDelete: SetNull)
  comments Comment[]
  votes    Vote[]
}

model Vote {
  id     String @id @default(cuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  contenu   String
  auteurNom String
  auteurId  String?
  postId    String
  creeLe    DateTime @default(now())

  auteur User? @relation(fields: [auteurId], references: [id], onDelete: SetNull)
  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String   // "comment"
  postId     String
  postTitre  String
  acteurNom  String
  lu         Boolean  @default(false)
  creeLe     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id       String   @id @default(cuid())
  type     String
  targetId String
  reason   String
  auteurId String?
  creeLe   DateTime @default(now())

  auteur User? @relation(fields: [auteurId], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  creeLe    DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
